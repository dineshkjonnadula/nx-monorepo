      "prefix": "lib",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": { "lintFilePatterns": ["shared/ui-components/**/*.ts"] }
        }
      }
    },
    "shared-data-access-api": {
      "projectType": "library",
      "root": "shared/data-access-api",
      "sourceRoot": "shared/data-access-api/src",
      "prefix": "lib",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": { "lintFilePatterns": ["shared/data-access-api/**/*.ts"] }
        }
      }
    },
    "shared-models": {
      "projectType": "library",
      "root": "shared/models",
      "sourceRoot": "shared/models/src",
      "prefix": "lib",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": { "lintFilePatterns": ["shared/models/**/*.ts"] }
        }
      }
    },
    "shared-util-helpers": {
      "projectType": "library",
      "root": "shared/util-helpers",
      "sourceRoot": "shared/util-helpers/src",
      "prefix": "lib",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": { "lintFilePatterns": ["shared/util-helpers/**/*.ts"] }
        }
      }
    },
    "shared-environments": {
      "projectType": "library",
      "root": "shared/environments",
      "sourceRoot": "shared/environments/src",
      "prefix": "lib",
      "architect": {
        "lint": {
